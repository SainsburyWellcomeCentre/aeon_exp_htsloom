                      <Property Name="EventSocket" Selector="EventSocket" />
                      <Property Name="RoomName" Selector="RoomName" />
                      <Property Name="CommandSocket" Selector="CommandSocket" />
                    </PropertyMappings>
                  </Expression>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>LightClient</Name>
                    <Description>Provides a network client for automated room light control.</Description>

<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:rx="clr-namespace:Bonsai.Reactive;assembly=Bonsai.Core"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:p1="clr-namespace:Harp.OutputExpander;assembly=Harp.OutputExpander"
                 xmlns:harp="clr-namespace:Bonsai.Harp;assembly=Bonsai.Harp"
                 xmlns:scr="clr-namespace:Bonsai.Scripting.Expressions;assembly=Bonsai.Scripting.Expressions"
                 xmlns:aeon="clr-namespace:Aeon.Acquisition;assembly=Aeon.Acquisition"
                 xmlns:dsp="clr-namespace:Bonsai.Dsp;assembly=Bonsai.Dsp"
                 xmlns:aeon-env="clr-namespace:Aeon.Environment;assembly=Aeon.Environment"
                 xmlns:io="clr-namespace:Bonsai.IO;assembly=Bonsai.System"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="rx:Defer">
        <Name>Alerts</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="GroupWorkflow">
              <Name>SubjectAlerts</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="rx:BehaviorSubject" TypeArguments="sys:String">
                    <rx:Name>SubjectAlertMessages</rx:Name>
                  </Expression>
                  <Expression xsi:type="IncludeWorkflow" Path="Aeon.Environment:EnvironmentCondition.bonsai">
                    <Value>Experiment</Value>
                  </Expression>
                  <Expression xsi:type="IncludeWorkflow" Path="Aeon.Acquisition:SendAlert.bonsai">
                    <ConfigFile>Z:\aeon\config\alerts.config</ConfigFile>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>FeederEvents</Name>
                  </Expression>
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="Count" DisplayName="DeliveryFailureThreshold" />
                  </Expression>
                  <Expression xsi:type="rx:SelectMany">
                    <Name>DispenserBroken</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="WorkflowInput">
                          <Name>Source1</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="rx:AsyncSubject">
                          <Name>Feeder</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>Feeder</Name>
                        </Expression>
                        <Expression xsi:type="MemberSelector">
                          <Selector>Key</Selector>
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>{0}</Format>
                          <Selector>it</Selector>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="rx:AsyncSubject">
                          <Name>FeederKeyString</Name>
                        </Expression>
                        <Expression xsi:type="GroupWorkflow">
                          <Name>PelletMonitor</Name>
                          <Description>Monitors pellet delivery state of commands and beam breaks.</Description>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>Feeder</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:Merge" />
                              </Expression>
                              <Expression xsi:type="p1:FilterRegister">
                                <harp:FilterType>Include</harp:FilterType>
                                <harp:Register xsi:type="p1:OutputSet" />
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="harp:FilterMessageType">
                                  <harp:FilterType>Include</harp:FilterType>
                                  <harp:MessageType>Write</harp:MessageType>
                                </Combinator>
                              </Expression>
                              <Expression xsi:type="scr:ExpressionTransform">
                                <scr:Expression>new(
False as Value,
it.GetTimestamp() as Timestamp
)</scr:Expression>
                              </Expression>
                              <Expression xsi:type="IncludeWorkflow" Path="Extensions\GetMatchingObservableGroup.bonsai">
                                <IGroupObservableSubjectMerge>FeederPelletDelivered</IGroupObservableSubjectMerge>
                                <Name>Feeder</Name>
                              </Expression>
                              <Expression xsi:type="scr:ExpressionTransform">
                                <scr:Expression>new(
True as Value,
Seconds as Timestamp)</scr:Expression>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:Merge" />
                              </Expression>
                              <Expression xsi:type="MemberSelector">
                                <Selector>Value,Timestamp</Selector>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="harp:CreateTimestamped" />
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="1" Label="Source1" />
                              <Edge From="1" To="2" Label="Source1" />
                              <Edge From="2" To="3" Label="Source1" />
                              <Edge From="3" To="4" Label="Source1" />
                              <Edge From="4" To="7" Label="Source1" />
                              <Edge From="5" To="6" Label="Source1" />
                              <Edge From="6" To="7" Label="Source2" />
                              <Edge From="7" To="8" Label="Source1" />
                              <Edge From="8" To="9" Label="Source1" />
                              <Edge From="9" To="10" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Count" />
                        </Expression>
                        <Expression xsi:type="rx:Condition">
                          <Name>DispenserBroken</Name>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="scr:ExpressionTransform">
                                <scr:Expression>Value ? 1 : 0</scr:Expression>
                              </Expression>
                              <Expression xsi:type="ExternalizedMapping">
                                <Property Name="Count" />
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:BufferCount">
                                  <rx:Count>5</rx:Count>
                                  <rx:Skip>1</rx:Skip>
                                </Combinator>
                              </Expression>
                              <Expression xsi:type="Add" />
                              <Expression xsi:type="GroupWorkflow">
                                <Name>Equal</Name>
                                <Workflow>
                                  <Nodes>
                                    <Expression xsi:type="WorkflowInput">
                                      <Name>Source1</Name>
                                    </Expression>
                                    <Expression xsi:type="ExternalizedMapping">
                                      <Property Name="Value" DisplayName="Count" />
                                    </Expression>
                                    <Expression xsi:type="Equal">
                                      <Operand xsi:type="IntProperty">
                                        <Value>5</Value>
                                      </Operand>
                                    </Expression>
                                    <Expression xsi:type="Equal">
                                      <Operand xsi:type="IntProperty">
                                        <Value>0</Value>
                                      </Operand>
                                    </Expression>
                                    <Expression xsi:type="Combinator">
                                      <Combinator xsi:type="rx:Zip" />
                                    </Expression>
                                    <Expression xsi:type="LogicalOr" />
                                    <Expression xsi:type="WorkflowOutput" />
                                  </Nodes>
                                  <Edges>
                                    <Edge From="0" To="2" Label="Source1" />
                                    <Edge From="0" To="3" Label="Source1" />
                                    <Edge From="1" To="2" Label="Source2" />
                                    <Edge From="2" To="4" Label="Source1" />
                                    <Edge From="3" To="4" Label="Source2" />
                                    <Edge From="4" To="5" Label="Source1" />
                                    <Edge From="5" To="6" Label="Source1" />
                                  </Edges>
                                </Workflow>
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="1" Label="Source1" />
                              <Edge From="1" To="3" Label="Source1" />
                              <Edge From="2" To="3" Label="Source2" />
                              <Edge From="2" To="5" Label="Source2" />
                              <Edge From="3" To="4" Label="Source1" />
                              <Edge From="4" To="5" Label="Source1" />
                              <Edge From="5" To="6" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="harp:ConvertTimestamped">
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>FeederKeyString</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:WithLatestFrom" />
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="2" Label="Source1" />
                              <Edge From="1" To="2" Label="Source2" />
                              <Edge From="2" To="3" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="IncludeWorkflow" Path="Extensions\AlertGate.bonsai">
                          <AlertRefractoryPeriod>PT5M</AlertRefractoryPeriod>
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>## **Dispenser Broken**
**Patch**: Patch{0}
</Format>
                          <Selector>Value.Item2</Selector>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>SubjectAlertMessages</Name>
                        </Expression>
                        <Expression xsi:type="aeon:FormatLogMessage">
                          <Format>Patch{0}</Format>
                          <Selector>Value.Item2</Selector>
                          <aeon:Priority>Alert</aeon:Priority>
                          <aeon:Type>DispenserBroken</aeon:Type>
                          <aeon:Timestamp />
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>AlertLogs</Name>
                        </Expression>
                        <Expression xsi:type="IncludeWorkflow" Path="Extensions\GetMatchingObservableGroup.bonsai">
                          <IGroupObservableSubjectMerge>FeederDispenser</IGroupObservableSubjectMerge>
                          <Name>Feeder</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>Feeder</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Merge" />
                        </Expression>
                        <Expression xsi:type="harp:Parse">
                          <harp:Register xsi:type="harp:ParseMessagePayload">
                            <harp:PayloadType>Timestamp</harp:PayloadType>
                            <harp:IsArray>false</harp:IsArray>
                          </harp:Register>
                        </Expression>
                        <Expression xsi:type="GroupWorkflow">
                          <Name>WithLatestTimestamp</Name>
                          <Description>Records the latest collected Harp timestamp for each element of the input sequence.</Description>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source2</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:WithLatestFrom" />
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="harp:CreateTimestamped" />
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="2" Label="Source1" />
                              <Edge From="1" To="2" Label="Source2" />
                              <Edge From="2" To="3" Label="Source1" />
                              <Edge From="3" To="4" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="PelletThreshold" />
                        </Expression>
                        <Expression xsi:type="rx:Condition">
                          <Name>LowFood</Name>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="MemberSelector">
                                <Selector>Value.Count</Selector>
                              </Expression>
                              <Expression xsi:type="ExternalizedMapping">
                                <Property Name="Value" DisplayName="PelletThreshold" Description="Below this value the low food alert will be raised." />
                              </Expression>
                              <Expression xsi:type="LessThan">
                                <Operand xsi:type="IntProperty">
                                  <Value>105</Value>
                                </Operand>
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="1" Label="Source1" />
                              <Edge From="1" To="3" Label="Source1" />
                              <Edge From="2" To="3" Label="Source2" />
                              <Edge From="3" To="4" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="IncludeWorkflow" Path="Extensions\AlertGate.bonsai">
                          <AlertRefractoryPeriod>PT5M</AlertRefractoryPeriod>
                        </Expression>
                        <Expression xsi:type="harp:ConvertTimestamped">
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>FeederKeyString</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:WithLatestFrom" />
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="2" Label="Source1" />
                              <Edge From="1" To="2" Label="Source2" />
                              <Edge From="2" To="3" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>## **Low Food**
**Patch**: {0}  
**Current Pellet Estimate**: {1}
</Format>
                          <Selector>Value.Item2,Value.Item1.Count</Selector>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>SubjectAlertMessages</Name>
                        </Expression>
                        <Expression xsi:type="aeon:FormatLogMessage">
                          <Format>Patch{0}	{1}</Format>
                          <Selector>Value.Item2,Value.Item1.Count</Selector>
                          <aeon:Priority>Alert</aeon:Priority>
                          <aeon:Type>LowFood</aeon:Type>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>AlertLogs</Name>
                        </Expression>
                        <Expression xsi:type="IncludeWorkflow" Path="Extensions\GetMatchingObservableGroup.bonsai">
                          <IGroupObservableSubjectMerge>FeederPelletMissed</IGroupObservableSubjectMerge>
                          <Name>Feeder</Name>
                        </Expression>
                        <Expression xsi:type="harp:ConvertTimestamped">
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>FeederKeyString</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:WithLatestFrom" />
                              </Expression>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>SubjectState</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:WithLatestFrom" />
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="2" Label="Source1" />
                              <Edge From="1" To="2" Label="Source2" />
                              <Edge From="2" To="4" Label="Source1" />
                              <Edge From="3" To="4" Label="Source2" />
                              <Edge From="4" To="5" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:ElementIndex" />
                        </Expression>
                        <Expression xsi:type="IncludeWorkflow" Path="Extensions\AlertGate.bonsai">
                          <AlertRefractoryPeriod>PT5M</AlertRefractoryPeriod>
                        </Expression>
                        <Expression xsi:type="MemberSelector">
                          <Selector>Value.Seconds,Index,Value.Value.Item2.Value.Id,Value.Value.Item1.Item2</Selector>
                        </Expression>
                        <Expression xsi:type="scr:ExpressionTransform">
                          <scr:Expression>new(
Item1 as Timestamp,
Item2 + 1 as Count,
Item3 as SubjectId,
Item4 as FeederId
)</scr:Expression>
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>## **Missed Pellet**
**Subject**: {0}
**Patch:**: Patch{1}
**Total Missed**: {2}
</Format>
                          <Selector>SubjectId,FeederId,Count</Selector>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>SubjectAlertMessages</Name>
                        </Expression>
                        <Expression xsi:type="aeon:FormatLogMessage">
                          <Format>{0}	Patch{1}	{2}</Format>
                          <Selector>SubjectId,FeederId,Count</Selector>
                          <aeon:Priority>Alert</aeon:Priority>
                          <aeon:Type>MissedPellet</aeon:Type>
                          <aeon:Timestamp>Timestamp</aeon:Timestamp>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>AlertLogs</Name>
                        </Expression>
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="1" Label="Source1" />
                        <Edge From="1" To="2" Label="Source1" />
                        <Edge From="3" To="4" Label="Source1" />
                        <Edge From="4" To="5" Label="Source1" />
                        <Edge From="5" To="6" Label="Source1" />
                        <Edge From="6" To="7" Label="Source1" />
                        <Edge From="8" To="10" Label="Source1" />
                        <Edge From="9" To="10" Label="Source2" />
                        <Edge From="10" To="11" Label="Source1" />
                        <Edge From="11" To="12" Label="Source1" />
                        <Edge From="12" To="13" Label="Source1" />
                        <Edge From="12" To="15" Label="Source1" />
                        <Edge From="13" To="14" Label="Source1" />
                        <Edge From="15" To="16" Label="Source1" />
                        <Edge From="17" To="21" Label="Source1" />
                        <Edge From="18" To="19" Label="Source1" />
                        <Edge From="19" To="20" Label="Source1" />
                        <Edge From="20" To="21" Label="Source2" />
                        <Edge From="21" To="23" Label="Source1" />
                        <Edge From="22" To="23" Label="Source2" />
                        <Edge From="23" To="24" Label="Source1" />
                        <Edge From="24" To="25" Label="Source1" />
                        <Edge From="25" To="26" Label="Source1" />
                        <Edge From="25" To="28" Label="Source1" />
                        <Edge From="26" To="27" Label="Source1" />
                        <Edge From="28" To="29" Label="Source1" />
                        <Edge From="30" To="31" Label="Source1" />
                        <Edge From="31" To="32" Label="Source1" />
                        <Edge From="32" To="33" Label="Source1" />
                        <Edge From="33" To="34" Label="Source1" />
                        <Edge From="34" To="35" Label="Source1" />
                        <Edge From="35" To="36" Label="Source1" />
                        <Edge From="35" To="38" Label="Source1" />
                        <Edge From="36" To="37" Label="Source1" />
                        <Edge From="38" To="39" Label="Source1" />
                      </Edges>
                    </Workflow>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>SubjectStart</Name>
                  </Expression>
                  <Expression xsi:type="rx:SelectMany">
                    <Name>SubjectTrackingAlerts</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="WorkflowInput">
                          <Name>Source1</Name>
                        </Expression>
                        <Expression xsi:type="rx:AsyncSubject">
                          <Name>ActiveSubject</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>TrackingEvents</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Merge" />
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>SubjectState</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:WithLatestFrom" />
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="DueTime" DisplayName="MissingTimeout" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Throttle">
                            <rx:DueTime>PT30M</rx:DueTime>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>## **Subject Missing**
**Subject**: {0}  
</Format>
                          <Selector>Item2.Value.Id</Selector>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>SubjectAlertMessages</Name>
                        </Expression>
                        <Expression xsi:type="aeon:FormatLogMessage">
                          <Format>{0}</Format>
                          <Selector>Item2.Value.Id</Selector>
                          <aeon:Priority>Alert</aeon:Priority>
                          <aeon:Type>TrackingFailure</aeon:Type>
                          <aeon:Timestamp>Item1.Seconds</aeon:Timestamp>
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>AlertLogs</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>TrackingEvents</Name>
                        </Expression>
                        <Expression xsi:type="rx:SelectMany">
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:Take">
                                  <rx:Count>1</rx:Count>
                                </Combinator>
                              </Expression>
                              <Expression xsi:type="rx:AsyncSubject">
                                <Name>TrakingEvents</Name>
                              </Expression>
                              <Expression xsi:type="SubscribeSubject">
                                <Name>TrakingEvents</Name>
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="rx:Merge" />
                              </Expression>
                              <Expression xsi:type="GroupWorkflow">
                                <Name>SpeedThreshold</Name>
                                <Workflow>
                                  <Nodes>
                                    <Expression xsi:type="WorkflowInput">
                                      <Name>Source1</Name>
                                    </Expression>
                                    <Expression xsi:type="harp:ConvertTimestamped">
                                      <Workflow>
                                        <Nodes>
                                          <Expression xsi:type="WorkflowInput">
                                            <Name>Source1</Name>
                                          </Expression>
                                          <Expression xsi:type="MemberSelector">
                                            <Selector>Item1</Selector>
                                          </Expression>
                                          <Expression xsi:type="WorkflowOutput" />
                                        </Nodes>
                                        <Edges>
                                          <Edge From="0" To="1" Label="Source1" />
                                          <Edge From="1" To="2" Label="Source1" />
                                        </Edges>
                                      </Workflow>
                                    </Expression>
                                    <Expression xsi:type="rx:Condition">
                                      <Workflow>
                                        <Nodes>
                                          <Expression xsi:type="WorkflowInput">
                                            <Name>Source1</Name>
                                          </Expression>
                                          <Expression xsi:type="MemberSelector">
                                            <Selector>Value.Count</Selector>
                                          </Expression>
                                          <Expression xsi:type="GreaterThan">
                                            <Operand xsi:type="IntProperty">
                                              <Value>0</Value>
                                            </Operand>
                                          </Expression>
                                          <Expression xsi:type="WorkflowOutput" />
                                        </Nodes>
                                        <Edges>
                                          <Edge From="0" To="1" Label="Source1" />
                                          <Edge From="1" To="2" Label="Source1" />
                                          <Edge From="2" To="3" Label="Source1" />
                                        </Edges>
                                      </Workflow>
                                    </Expression>
                                    <Expression xsi:type="MemberSelector">
                                      <Selector>Value[0].Centroid</Selector>
                                    </Expression>
                                    <Expression xsi:type="Combinator">
                                      <Combinator xsi:type="dsp:Difference">
                                        <dsp:Order>1</dsp:Order>
                                      </Combinator>
                                    </Expression>
                                    <Expression xsi:type="Combinator">
                                      <Combinator xsi:type="dsp:Norm">
                                        <dsp:NormType>L2</dsp:NormType>
                                      </Combinator>
                                    </Expression>
                                    <Expression xsi:type="ExternalizedMapping">
                                      <Property Name="Value" DisplayName="MaxSpeed" />
                                    </Expression>
                                    <Expression xsi:type="GreaterThan">
                                      <Operand xsi:type="DoubleProperty">
                                        <Value>500</Value>
                                      </Operand>
                                    </Expression>
                                    <Expression xsi:type="MemberSelector">
                                      <Selector>Seconds</Selector>
